# =============================================================================
# FAST RESUME — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# =============================================================================

# --- Gemini API (OBLIGATOIRE) ------------------------------------------------
# Clé API Google Gemini pour les fonctions IA :
#   - Amélioration de texte CV
#   - Analyse ATS (compatibilité offre d'emploi)
#   - Extraction CV depuis PDF/image
# Obtenir une clé : https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# --- Mode application --------------------------------------------------------
# Contrôle le comportement de l'app selon l'environnement
# Valeurs possibles :
#   development  → logs verbeux, pas de minification (défaut local)
#   production   → optimisé, logs réduits
#   staging      → comme production mais sur env de test
VITE_APP_MODE=development

# --- Credentials par défaut --------------------------------------------------
# Utilisateur et mot de passe par défaut (si auth ajoutée plus tard)
# Non utilisés actuellement dans le code
VITE_DEFAULT_USER=admin
VITE_DEFAULT_PASS=your_password_here
